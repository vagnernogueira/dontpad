#!/bin/sh

set -eu

skills_prefix="_docs/ia-context/skills"

if [ "${ALLOW_SKILLS_CHANGES:-0}" = "1" ]; then
	exit 0
fi

if git diff --cached --name-only -- "$skills_prefix" | grep -q .; then
	echo >&2 "Commit bloqueado: alterações em $skills_prefix so podem entrar via sync-skills."
	echo >&2 "Use 'make -f _docs/ia-context/skills/Makefile sync-skills' ou exporte ALLOW_SKILLS_CHANGES=1 para um fluxo excepcional consciente."
	exit 1
fi
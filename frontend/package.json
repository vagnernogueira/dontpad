{
    "name": "dontpad-frontend",
    "private": true,
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite --port 3000",
        "build": "vue-tsc && vite build",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "preview": "vite preview",
        "lint": "eslint src --ext .ts,.vue",
        "lint:fix": "eslint src --ext .ts,.vue --fix",
        "format": "prettier --write src",
        "shadcn:info": "npx --yes shadcn-vue@latest info",
        "shadcn:add": "npx --yes shadcn-vue@latest add"
    },
    "dependencies": {
        "@codemirror/lang-markdown": "^6.3.4",
        "@codemirror/language": "^6.11.3",
        "@codemirror/state": "^6.5.2",
        "@codemirror/view": "^6.26.0",
        "@lezer/highlight": "^1.2.3",
        "@types/node": "^25.5.0",
        "@vue/devtools-api": "^6.6.4",
        "@vueuse/core": "^14.2.1",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "codemirror": "^6.0.2",
        "dompurify": "^3.4.0",
        "html2pdf.js": "^0.14.0",
        "lucide-vue-next": "^0.575.0",
        "markdown-it": "^14.1.1",
        "marked": "^17.0.3",
        "reka-ui": "^2.9.2",
        "tailwind-merge": "^3.5.0",
        "vue": "^3.4.21",
        "vue-router": "^4.3.0",
        "y-codemirror.next": "^0.3.5",
        "y-prosemirror": "^1.3.7",
        "y-websocket": "^1.5.0",
        "yjs": "^13.6.14"
    },
    "overrides": {
        "y-leveldb": "file:vendor/y-leveldb-empty"
    },
    "devDependencies": {
        "@eslint/js": "^9.0.0",
        "@tailwindcss/postcss": "^4.2.2",
        "@testing-library/jest-dom": "^6.8.0",
        "@testing-library/vue": "^8.1.0",
        "@vitejs/plugin-vue": "^5.0.4",
        "@vitest/coverage-v8": "^3.2.4",
        "eslint": "^9.0.0",
        "eslint-config-prettier": "^9.0.0",
        "eslint-plugin-vue": "^9.0.0",
        "globals": "^15.0.0",
        "jsdom": "^26.1.0",
        "postcss": "^8.5.9",
        "prettier": "^3.0.0",
        "tailwindcss": "^4.2.2",
        "tailwindcss-animate": "^1.0.7",
        "typescript": "^5.2.2",
        "typescript-eslint": "^8.0.0",
        "vite": "^5.2.0",
        "vitest": "^3.2.4",
        "vue-tsc": "^2.0.6"
    }
}
